APP_NAME='TSU Homebase'
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://tsu-homebase-vault.test
ASSET_URL=https://tsu-homebase-vault.

FRONTEND_URL=https://tsu-homebase-vault.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
# DB_HOST=<IP-address>
# DB_PORT=3306
# DB_DATABASE=tsu_homebase
# DB_USERNAME=<your-username>
# DB_PASSWORD=<your-password>

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=tsu-homebase-vault.test
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Ubah dari database ke file jika production
CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=tsu-homebase-vault.test
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@tsu.ac.id"
MAIL_FROM_NAME="${APP_NAME}"
# sesuaikan dengan port
MAIL_ENCRYPTION=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

PASSPORT_PASSWORD_GRANT_CLIENT_ID=
PASSPORT_PASSWORD_GRANT_CLIENT_SECRET=

PASSPORT_AUTHORIZATION_GRANT_CLIENT_ID=
PASSPORT_AUTHORIZATION_GRANT_CLIENT_SECRET=

# Emergency Secret Key
# Signature URL dari Homebase (Harus SAMA dengan Homebase)
PIKDI_EMERGENCY_SECRET=MASUKKAN_SECRET_KEY

# Untuk Password Login Manual (Secret dari Hash)
PIKDI_RESCUE_SECRET=MASUKKAN_SECRET_KEY
